PORT=5010
NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net
MONGODB_DB_NAME=ecosoulhomepo
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://your-domain.com
ALLOW_SIGNUP=false
MAX_UPLOAD_FILE_MB=25
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_MAX=120
RATE_LIMIT_UPLOAD_MAX=10
MAX_UPLOAD_ROWS=150000
API_REQUEST_LOG=true
API_REQUEST_LOG_SKIP_HEALTH=true
